# Cricklytics — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit the .env file to GitHub.

# ── CricAPI (cricapi.com) ─────────────────────────────────────────────────────
# Lifetime Free key from https://cricapi.com — used for live match data & scorecards
# Requires VPN on some networks (e.g. university/office)
CRICAPI_KEY=your_cricapi_key_here

# ── Cricbuzz via RapidAPI ─────────────────────────────────────────────────────
# Free tier key from https://rapidapi.com/cricbuzz/api/cricbuzz-cricket
# Used by scrape_matches.py for weekly schedule refresh (500 req/month free)
RAPIDAPI_KEY=your_rapidapi_key_here
